  "keyFeatures": [
    "Auto-generated CRUD endpoints with @Crud() decorator",
    "Advanced query parsing with filtering, pagination, sorting, and relations",
    "TypeORM integration with TypeOrmCrudService",
    "Request query builder for frontend usage",
    "Swagger/OpenAPI documentation generation",
    "Route customization and override capabilities",
    "Built-in validation with class-validator",
    "Soft delete support",
    "Authentication and authorization hooks",
    "Response serialization control"
  ],
  "publicApiSurface": [
    "@Crud() - Main decorator for generating CRUD endpoints",
    "@CrudAuth() - Authentication decorator",
    "@Override() - Route override decorator",
    "@ParsedRequest() - Access parsed request parameters",
    "@ParsedBody() - Access parsed request body",
    "TypeOrmCrudService - Base service class for TypeORM",
    "CrudService - Abstract base service class",
    "RequestQueryBuilder - Frontend query builder",
    "RequestQueryParser - Backend query parser",
    "CrudOptions - Configuration interface",
    "QueryOptions - Query configuration interface",
    "RoutesOptions - Route configuration interface",
    "getMany() - Get multiple resources",
    "getOne() - Get single resource",
    "createOne() - Create single resource",
    "createMany() - Create multiple resources",
    "updateOne() - Update single resource",
    "replaceOne() - Replace single resource",
    "deleteOne() - Delete single resource",
    "recoverOne() - Recover soft-deleted resource"
  ]
